config rukiki 'main'
	option enabled '1'
	option mode 'auto'
	option fail_mode 'open'
	option auto_best_server '1'
	option auto_failover '1'
	option bypass_blocks '1'
	option ru_direct '1'
	option auto_update_lists '1'

config subscription 'subscription'
	option url 'https://example.com/sub?token=SECRET123'
	option user_agent 'clash.meta'
	option auto_update '1'
	option update_interval '86400'

config dns 'dns'
	option enhanced_mode 'fake-ip'
	list bootstrap '9.9.9.9'
	list bootstrap '77.88.8.8'
	option direct_resolver 'https://77.88.8.8/dns-query'
	option proxy_resolver 'https://1.1.1.1/dns-query'
	option ipv6 '0'

config security 'security'
	option mask_subscription_url '1'
	option yacd_wan_access '0'

config ruleset 'allowlist'
	option enabled '1'
	option role 'allowlist'
	option behavior 'domain'
	option action 'direct'
	option url 'https://lists.example/allowlist.mrs'
	option interval '86400'

config ruleset 'blocked'
	option enabled '1'
	option role 'blocked'
	option behavior 'domain'
	option action 'proxy'
	option url 'https://lists.example/blocked.mrs'
	option interval '86400'

config ruleset 'geoblock'
	option enabled '1'
	option role 'geoblock'
	option behavior 'domain'
	option action 'proxy'
	option url 'https://lists.example/geoblock.mrs'
	option interval '86400'

config ruleset 'ru_ip'
	option enabled '1'
	option role 'ru_ip'
	option behavior 'ipcidr'
	option action 'direct'
	option url 'https://lists.example/ru-ip.mrs'
	option interval '86400'

config ruleset 'youtube'
	option enabled '1'
	option role 'service'
	option behavior 'domain'
	option action 'proxy'
	option url 'https://lists.example/youtube.mrs'
	option interval '86400'

config ruleset 'media'
	option enabled '1'
	option role 'service'
	option behavior 'domain'
	option action 'proxy'
	option url ''
	option interval '86400'

config rule
	option enabled '1'
	option domain 'gosuslugi.ru'
	option action 'direct'

config rule
	option enabled '1'
	option domain 'youtube.com'
	option action 'vpn'
