# === Пользовательские правила =================================
# Высший приоритет; переживают обновления списков (хранятся здесь,
# а не в скачиваемых наборах). Генератор кладёт их ПЕРВЫМИ.
#   action: vpn    -> правило ...,PROXY  (prepend)
#           direct -> правило ...,DIRECT (prepend)
#           auto   -> правило НЕ создаётся (решают автосписки)
#
# Примеры (по умолчанию правил нет):
# config rule
#	option enabled '1'
#	option domain 'youtube.com'
#	option action 'vpn'
#
# config rule
#	option enabled '1'
#	option domain 'gosuslugi.ru'
#	option action 'direct'
