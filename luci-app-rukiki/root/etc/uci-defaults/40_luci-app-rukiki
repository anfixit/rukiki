#!/bin/sh
# Подписка хранит секрет (url) — ограничиваем доступ к конфигу.
[ -f /etc/config/rukiki ] && chmod 600 /etc/config/rukiki
# Сбрасываем кэш LuCI и перечитываем ACL/меню.
rm -f /tmp/luci-indexcache* 2>/dev/null
rm -rf /tmp/luci-modulecache 2>/dev/null
/etc/init.d/rpcd reload 2>/dev/null
# НЕ запускаем генератор здесь: подписки ещё нет. Применит apply.
exit 0
